@page "/"

<PageTitle>Shiny Controls</PageTitle>

<div class="hero">
    <div class="hero-bg">
        <div class="hero-circle hero-circle-1"></div>
        <div class="hero-circle hero-circle-2"></div>
    </div>
    <div class="hero-content">
        <img src="css/shiny_logo.png" alt="Shiny Controls" class="hero-logo" />
        <h1 class="hero-title">Shiny Controls</h1>
        <div class="hero-divider"></div>
        <p class="hero-subtitle">MAUI &amp; Blazor Component Gallery</p>
    </div>
</div>

<p class="intro-text">
    Explore the full suite of UI controls. Pick a category from the sidebar to get started.
</p>

<div class="feature-grid">
    <div class="feature-card">
        <div class="feature-card-icon" style="color:#0891B2;">&#x25A3;</div>
        <h3>Floating Panels</h3>
        <p>Bottom sheets, top panels, dual panels, and header-peek drawers for layered layouts.</p>
    </div>
    <div class="feature-card">
        <div class="feature-card-icon" style="color:#059669;">&#x2699;</div>
        <h3>Controls</h3>
        <p>Pills, FAB menus, security PIN, color picker, autocomplete, signature pad, and more.</p>
    </div>
    <div class="feature-card">
        <div class="feature-card-icon" style="color:#D97706;">&#x2630;</div>
        <h3>Table View</h3>
        <p>Settings-style sectioned lists with drag &amp; sort, pickers, dynamic sections, and custom styling.</p>
    </div>
    <div class="feature-card">
        <div class="feature-card-icon" style="color:#DC2626;">&#x25A1;</div>
        <h3>Scheduler</h3>
        <p>Calendar, agenda, event list, and combined calendar-picker views with custom event providers.</p>
    </div>
    <div class="feature-card">
        <div class="feature-card-icon" style="color:#9333EA;">&#x25A3;</div>
        <h3>Media</h3>
        <p>Image viewer with zoom/pan, gallery mode, and a full image editor with crop, rotate, and draw.</p>
    </div>
    <div class="feature-card">
        <div class="feature-card-icon" style="color:#0284C7;">&#x2709;</div>
        <h3>Communication</h3>
        <p>Chat interface with typing indicators, attachments, and frosted glass overlays.</p>
    </div>
    <div class="feature-card">
        <div class="feature-card-icon" style="color:#65A30D;">&#x2193;</div>
        <h3>Content</h3>
        <p>Full Markdown renderer and editor powered by Markdig, with live preview.</p>
    </div>
    <div class="feature-card">
        <div class="feature-card-icon" style="color:#E11D48;">&#x2B13;</div>
        <h3>Diagrams</h3>
        <p>Mermaid.js diagrams — flowcharts, directions, themes, subgraphs, and an interactive editor.</p>
    </div>
</div>
