@page "/slider"

<PageTitle>Gradient Slider</PageTitle>

<h1>Gradient Slider</h1>

<div class="demo-section">
    <h2>Basic (Temperature)</h2>
    <Slider @bind-Value="temperature"
                    Minimum="0"
                    Maximum="100"
                    ValueFormat="0°" />
    <div class="state">Temperature: <code>@temperature.ToString("0")°</code></div>
</div>

<div class="demo-section">
    <h2>Custom Colors (Green to Yellow)</h2>
    <Slider @bind-Value="intensity"
                    Minimum="0"
                    Maximum="10"
                    Step="0.5"
                    ColdColor="#10B981"
                    HotColor="#F59E0B"
                    ValueFormat="0.#" />
    <div class="state">Intensity: <code>@intensity.ToString("0.#")</code></div>
</div>

<div class="demo-section">
    <h2>Large Thumb, Tall Track</h2>
    <Slider @bind-Value="volume"
                    Minimum="0"
                    Maximum="100"
                    TrackHeight="12"
                    ThumbSize="32"
                    ColdColor="#6366F1"
                    HotColor="#EC4899" />
    <div class="state">Volume: <code>@volume.ToString("0")</code></div>
</div>

<div class="demo-section">
    <h2>No Tooltip</h2>
    <Slider @bind-Value="opacity"
                    Minimum="0"
                    Maximum="1"
                    Step="0.01"
                    ShowTooltip="false"
                    ColdColor="#94A3B8"
                    HotColor="#1E293B"
                    ValueFormat="P0" />
    <div class="state">Opacity: <code>@opacity.ToString("P0")</code></div>
</div>

<div class="demo-section">
    <h2>Custom Tooltip Template</h2>
    <Slider @bind-Value="rating" Minimum="1" Maximum="5" Step="1">
        <TooltipTemplate Context="val">
            <div style="background: #7C3AED; color: white; padding: 6px 14px; border-radius: 8px; font-weight: bold;">
                @GetStars((int)val)
            </div>
        </TooltipTemplate>
    </Slider>
    <div class="state">Rating: <code>@GetStars((int)rating)</code></div>
</div>

<div class="demo-section">
    <h2>Disabled</h2>
    <Slider Value="65" IsEnabled="false" />
</div>

@code {
    double temperature = 50;
    double intensity = 5;
    double volume = 30;
    double opacity = 0.75;
    double rating = 3;

    string GetStars(int count) => new string('\u2B50', count);
}
