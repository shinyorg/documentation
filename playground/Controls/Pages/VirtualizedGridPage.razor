@page "/virtualizedgrid"

<PageTitle>Virtualized Grid</PageTitle>

<h1>Virtualized Grid</h1>

<section class="demo-section">
    <h2>Basic Grid</h2>
    <div style="margin-bottom:12px;">
        <label>Columns: </label>
        <button @onclick="@(() => basicColumns = Math.Max(1, basicColumns - 1))">-</button>
        <strong>@basicColumns</strong>
        <button @onclick="@(() => basicColumns = Math.Min(6, basicColumns + 1))">+</button>
    </div>

    <VirtualizedGrid TItem="GridItem" Items="@basicItems" ColumnCount="@basicColumns"
                     ItemSpacing="8" CellPaddingLeft="4" CellPaddingRight="4"
                     CellPaddingTop="4" CellPaddingBottom="4"
                     ItemSelected="@(item => selectedBasic = item.Name)">
        <ItemTemplate Context="item">
            <div style="padding:16px;border-radius:8px;background:@item.Color;color:white;text-align:center;">
                <div style="font-size:24px;">@item.Icon</div>
                <div style="font-weight:600;margin-top:4px;">@item.Name</div>
            </div>
        </ItemTemplate>
        <EmptyViewTemplate>
            <p>No items yet.</p>
        </EmptyViewTemplate>
    </VirtualizedGrid>

    @if (selectedBasic is not null)
    {
        <p style="margin-top:8px;">Selected: <strong>@selectedBasic</strong></p>
    }
</section>

<section class="demo-section">
    <h2>Grouped Grid with Sticky Headers</h2>

    <VirtualizedGrid TItem="GridItem" Items="@(groupedData.SelectMany(g => g.Items).ToList())"
                     IsGroupingEnabled="true" GroupedItems="@groupedData"
                     HasStickyHeaders="true" ColumnCount="3" ItemSpacing="8"
                     CellPaddingLeft="4" CellPaddingRight="4" CellPaddingTop="4" CellPaddingBottom="4">
        <GroupHeaderTemplate Context="key">
            <div style="padding:8px 12px;background:#2D3748;color:white;border-radius:6px;font-weight:600;">
                @key
            </div>
        </GroupHeaderTemplate>
        <ItemTemplate Context="item">
            <div style="padding:12px;border-radius:8px;background:@item.Color;color:white;text-align:center;">
                <div style="font-size:20px;">@item.Icon</div>
                <div style="font-size:13px;margin-top:4px;">@item.Name</div>
            </div>
        </ItemTemplate>
    </VirtualizedGrid>
</section>

<section class="demo-section">
    <h2>Virtualized (Large Dataset)</h2>
    <div style="height:400px;overflow-y:auto;border:1px solid #e2e8f0;border-radius:8px;">
        <VirtualizedGrid TItem="GridItem" Items="@largeDataset" EnableVirtualization="true"
                         ColumnCount="4" ItemSpacing="6"
                         CellPaddingLeft="4" CellPaddingRight="4" CellPaddingTop="4" CellPaddingBottom="4">
            <ItemTemplate Context="item">
                <div style="padding:10px;border-radius:6px;background:@item.Color;color:white;text-align:center;font-size:13px;">
                    @item.Icon @item.Name
                </div>
            </ItemTemplate>
        </VirtualizedGrid>
    </div>
    <p style="margin-top:4px;font-size:13px;color:#718096;">@largeDataset.Count items with virtualization</p>
</section>

<section class="demo-section">
    <h2>With Header, Footer &amp; Load More</h2>

    <VirtualizedGrid TItem="GridItem" Items="@loadMoreItems" ColumnCount="3" ItemSpacing="8"
                     CellPaddingLeft="4" CellPaddingRight="4" CellPaddingTop="4" CellPaddingBottom="4"
                     ShowLoadMoreButton="@canLoadMore" IsLoadingMore="@isLoading"
                     LoadMoreRequested="@OnLoadMore">
        <HeaderTemplate>
            <div style="padding:12px;background:linear-gradient(135deg,#667EEA,#764BA2);color:white;border-radius:8px;text-align:center;margin-bottom:8px;">
                <strong>Featured Collection</strong>
            </div>
        </HeaderTemplate>
        <ItemTemplate Context="item">
            <div style="padding:12px;border-radius:8px;background:@item.Color;color:white;text-align:center;">
                <div style="font-size:20px;">@item.Icon</div>
                <div style="font-size:13px;margin-top:4px;">@item.Name</div>
            </div>
        </ItemTemplate>
        <FooterTemplate>
            <div style="padding:8px;text-align:center;font-size:12px;color:#A0AEC0;margin-top:8px;">
                Showing @loadMoreItems.Count of @totalItems items
            </div>
        </FooterTemplate>
    </VirtualizedGrid>
</section>

@code {
    int basicColumns = 3;
    string? selectedBasic;
    bool isLoading;
    bool canLoadMore = true;
    int totalItems = 30;

    static readonly string[] colors = { "#E53E3E", "#DD6B20", "#38A169", "#3182CE", "#805AD5", "#D53F8C", "#319795", "#B7791F" };
    static readonly string[] icons = { "🎯", "⚡", "🌟", "🔥", "💎", "🎪", "🌈", "🎸" };

    List<GridItem> basicItems = Enumerable.Range(1, 12)
        .Select(i => new GridItem($"Item {i}", colors[(i - 1) % colors.Length], icons[(i - 1) % icons.Length]))
        .ToList();

    List<VirtualizedGridGroup<GridItem>> groupedData = new()
    {
        new("Fruits", new List<GridItem>
        {
            new("Apple", "#E53E3E", "🍎"), new("Banana", "#DD6B20", "🍌"),
            new("Cherry", "#C53030", "🍒"), new("Grape", "#805AD5", "🍇"),
            new("Kiwi", "#38A169", "🥝"), new("Mango", "#D69E2E", "🥭"),
        }),
        new("Vegetables", new List<GridItem>
        {
            new("Carrot", "#ED8936", "🥕"), new("Broccoli", "#48BB78", "🥦"),
            new("Corn", "#ECC94B", "🌽"), new("Pepper", "#FC8181", "🌶️"),
            new("Tomato", "#F56565", "🍅"),
        }),
        new("Snacks", new List<GridItem>
        {
            new("Cookie", "#B7791F", "🍪"), new("Donut", "#D53F8C", "🍩"),
            new("Popcorn", "#F6E05E", "🍿"), new("Candy", "#F687B3", "🍬"),
        }),
    };

    List<GridItem> largeDataset = Enumerable.Range(1, 500)
        .Select(i => new GridItem($"#{i}", colors[(i - 1) % colors.Length], icons[(i - 1) % icons.Length]))
        .ToList();

    List<GridItem> loadMoreItems = Enumerable.Range(1, 9)
        .Select(i => new GridItem($"Item {i}", colors[(i - 1) % colors.Length], icons[(i - 1) % icons.Length]))
        .ToList();

    async Task OnLoadMore()
    {
        isLoading = true;
        StateHasChanged();
        await Task.Delay(800);

        var next = Enumerable.Range(loadMoreItems.Count + 1, 6)
            .Select(i => new GridItem($"Item {i}", colors[(i - 1) % colors.Length], icons[(i - 1) % icons.Length]))
            .ToList();
        loadMoreItems.AddRange(next);

        if (loadMoreItems.Count >= totalItems)
            canLoadMore = false;

        isLoading = false;
    }

    record GridItem(string Name, string Color, string Icon);
}
