@page "/colorpicker"

<PageTitle>Color Picker</PageTitle>

<h1>Color Picker</h1>

<div class="demo-section">
    <ColorPicker @bind-SelectedColor="selectedColor"
                 ShowOpacity="showOpacity" />

    <div style="margin-top:16px; padding:20px; border-radius:12px; text-align:center;
                border:1px solid #ccc; background:@selectedColor; color:white;
                font-weight:bold; font-size:18px; text-shadow: 0 1px 2px rgba(0,0,0,0.5);">
        @selectedColor
    </div>

    <div style="margin-top:12px;">
        <label>
            <input type="checkbox" @bind="showOpacity" /> Show Opacity
        </label>
    </div>
</div>

@code {
    string selectedColor = "#6495ED";
    bool showOpacity = true;
}
