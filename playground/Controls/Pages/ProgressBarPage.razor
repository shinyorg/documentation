@page "/progressbar"

<PageTitle>Progress Bar</PageTitle>

<h1>Progress Bar</h1>

<section class="demo-section">
    <h2>Basic</h2>
    <ProgressBar Value="@value" TrackHeight="10" CornerRadius="5px" />
</section>

<section class="demo-section">
    <h2>With Text</h2>
    <ProgressBar Value="@value" TrackHeight="20" CornerRadius="10px" ShowText="true" FontSize="11" />
</section>

<section class="demo-section">
    <h2>Gradient Fill</h2>
    <ProgressBar Value="@value"
                 TrackHeight="12"
                 CornerRadius="6px"
                 UseGradient="true"
                 GradientStartColor="#3B82F6"
                 GradientEndColor="#8B5CF6" />
</section>

<section class="demo-section">
    <h2>Gradient + Text</h2>
    <ProgressBar Value="@value"
                 TrackHeight="22"
                 CornerRadius="11px"
                 UseGradient="true"
                 GradientStartColor="#10B981"
                 GradientEndColor="#F59E0B"
                 ShowText="true" />
</section>

<section class="demo-section">
    <h2>Pulse on Value Change (Vista shimmer)</h2>
    <ProgressBar Value="@value"
                 TrackHeight="12"
                 CornerRadius="6px"
                 UseGradient="true"
                 GradientStartColor="#EC4899"
                 GradientEndColor="#F97316"
                 PulseEnabled="true"
                 PulseOnValueChange="true"
                 PulseLength="0.4"
                 PulseSpeed="800" />
</section>

<section class="demo-section">
    <h2>Pulse on Interval (2s, wide sheen)</h2>
    <ProgressBar Value="@value"
                 TrackHeight="12"
                 CornerRadius="6px"
                 UseGradient="true"
                 GradientStartColor="#6366F1"
                 GradientEndColor="#EC4899"
                 PulseEnabled="true"
                 PulseOnValueChange="false"
                 PulseInterval="@TimeSpan.FromSeconds(2)"
                 PulseLength="0.6"
                 PulseSpeed="1200" />
</section>

<section class="demo-section">
    <h2>Fast Narrow Pulse (every 1s)</h2>
    <ProgressBar Value="@value"
                 TrackHeight="10"
                 CornerRadius="5px"
                 BarColor="#10B981"
                 PulseEnabled="true"
                 PulseOnValueChange="false"
                 PulseInterval="@TimeSpan.FromSeconds(1)"
                 PulseLength="0.2"
                 PulseSpeed="500" />
</section>

<section class="demo-section">
    <h2>Indeterminate</h2>
    <ProgressBar IsIndeterminate="true"
                 TrackHeight="8"
                 CornerRadius="4px"
                 UseGradient="true"
                 GradientStartColor="#14B8A6"
                 GradientEndColor="#3B82F6" />
</section>

<section class="demo-section">
    <h2>Controls</h2>
    <div style="display: flex; gap: 12px; margin-bottom: 12px;">
        <button class="btn btn-primary" @onclick="Decrement">- 10</button>
        <button class="btn btn-primary" @onclick="Increment">+ 10</button>
    </div>
    <p>Value: @value.ToString("0")</p>
</section>

@code {
    double value = 45;

    void Increment() => value = Math.Min(100, value + 10);
    void Decrement() => value = Math.Max(0, value - 10);
}
