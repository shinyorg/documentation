@page "/overlay"

<PageTitle>Overlay</PageTitle>

<h1>Overlay</h1>

<section class="demo-section">
    <h2>Custom Overlay</h2>
    <p>Shows a configurable overlay with custom content.</p>
    <button class="btn btn-primary" @onclick="() => showCustom = true">Show Custom Overlay</button>
</section>

<section class="demo-section">
    <h2>Loading Overlay (Indeterminate)</h2>
    <p>Shows a spinner with a message.</p>
    <button class="btn btn-primary" @onclick="ShowIndeterminate">Show Loading (Spinner)</button>
</section>

<section class="demo-section">
    <h2>Loading Overlay (Determinate)</h2>
    <p>Shows a progress bar that fills to 100%.</p>
    <button class="btn btn-primary" @onclick="ShowDeterminate">Show Loading (Progress Bar)</button>
</section>

<Overlay IsShown="@showCustom" OverlayColor="rgba(128, 0, 128, 0.7)">
    <OverlayContent>
        <div style="text-align: center; color: white;">
            <h2>Custom Overlay Content</h2>
            <p>Tap the button below to dismiss</p>
            <button class="btn btn-light" @onclick="() => showCustom = false">Dismiss</button>
        </div>
    </OverlayContent>
</Overlay>

<LoadingOverlay IsShown="@showLoading"
               IsIndeterminate="@isIndeterminate"
               Progress="@progress"
               Message="@message" />

@code {
    bool showCustom;
    bool showLoading;
    bool isIndeterminate = true;
    double progress;
    string? message;

    async Task ShowIndeterminate()
    {
        isIndeterminate = true;
        message = "Loading, please wait...";
        showLoading = true;
        StateHasChanged();

        await Task.Delay(3000);
        showLoading = false;
    }

    async Task ShowDeterminate()
    {
        isIndeterminate = false;
        progress = 0;
        message = "Downloading...";
        showLoading = true;
        StateHasChanged();

        for (var i = 0; i <= 100; i += 5)
        {
            progress = i;
            StateHasChanged();
            await Task.Delay(100);
        }

        message = "Complete!";
        StateHasChanged();
        await Task.Delay(500);
        showLoading = false;
    }
}
