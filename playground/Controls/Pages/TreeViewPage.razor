@page "/treeview"

<PageTitle>Tree View</PageTitle>

<h1>Tree View</h1>

<p>
    File browser demo with a synchronous in-memory tree plus one lazy-loaded "Cloud" branch.
    Locked rows can't be selected. Try the keyboard: arrow keys to navigate, Enter to select,
    left/right to collapse/expand. Drag a row onto another to reorder.
</p>

<div class="toolbar">
    <button @onclick="ExpandAll">Expand all</button>
    <button @onclick="CollapseAll">Collapse all</button>
    <button @onclick="RefreshCloud">Refresh Cloud</button>
    <label>
        <input type="checkbox" @bind="multiSelect" /> Multi-select
    </label>
</div>

<TreeView TItem="FileNode"
          @ref="tree"
          ItemsSource="rootItems"
          ChildrenSelector="@(n => n.LazyLoad ? null : n.Children)"
          ChildrenLoader="LoadCloudChildren"
          HasChildrenSelector="@(n => n.IsFolder)"
          CanExpandSelector="@(n => n.IsFolder)"
          CanSelectSelector="@(n => !n.IsLocked)"
          SelectionMode="@(multiSelect ? BlazorTreeSelectionMode.Multiple : BlazorTreeSelectionMode.Single)"
          EnableDragDrop="true"
          ShowGuideLines="true"
          IndentSize="22"
          ChevronColor="#7C3AED"
          ItemSelected="OnSelected"
          ItemExpanded="OnExpanded"
          ItemCollapsed="OnCollapsed"
          ItemDropped="OnDropped"
          LoadFailed="OnLoadFailed">
    <ItemTemplate Context="node">
        <div class="row" style="@(node.IsLocked ? "opacity:0.5;" : "")">
            <span class="icon">@node.Icon</span>
            <span>@node.Name</span>
        </div>
    </ItemTemplate>
</TreeView>

<p class="status">@status</p>

<style>
    .toolbar { display:flex; gap:8px; align-items:center; margin-bottom:12px; }
    .toolbar button { padding:6px 12px; }
    .row { display:flex; gap:8px; align-items:center; }
    .icon { font-size:16px; }
    .status { margin-top:12px; font-size:12px; color:#666; }
</style>

@code {
    TreeView<FileNode>? tree;
    bool multiSelect;
    string status = "Tap or arrow-key through the tree.";

    readonly List<FileNode> rootItems = new()
    {
        new() { Name = "Documents", Icon = "📁", IsFolder = true, Children = new()
            {
                new() { Name = "Projects", Icon = "📁", IsFolder = true, Children = new()
                    {
                        new() { Name = "design.sketch", Icon = "🎨" },
                        new() { Name = "spec.md", Icon = "📄" },
                        new() { Name = "src", Icon = "📁", IsFolder = true, Children = new()
                            {
                                new() { Name = "Program.cs", Icon = "💾" },
                                new() { Name = "App.xaml", Icon = "🖼️" }
                            }
                        }
                    }
                },
                new() { Name = "readme.txt", Icon = "📄" },
                new() { Name = "secret.key", Icon = "🔒", IsLocked = true }
            }
        },
        new() { Name = "Downloads", Icon = "📁", IsFolder = true, Children = new()
            {
                new() { Name = "installer.dmg", Icon = "💿" },
                new() { Name = "photo.png", Icon = "🖼️" }
            }
        },
        new() { Name = "Cloud (lazy)", Icon = "☁️", IsFolder = true, LazyLoad = true },
        new() { Name = "todo.txt", Icon = "📄" }
    };

    async Task<IEnumerable<FileNode>> LoadCloudChildren(FileNode parent)
    {
        if (!parent.LazyLoad)
            return Array.Empty<FileNode>();
        await Task.Delay(900);
        return new[]
        {
            new FileNode { Name = "remote-backup.zip", Icon = "💾" },
            new FileNode { Name = "shared", Icon = "📁", IsFolder = true, LazyLoad = true },
            new FileNode { Name = "presentation.pptx", Icon = "📊" }
        };
    }

    async Task ExpandAll() { if (tree != null) await tree.ExpandAllAsync(); }
    void CollapseAll() => tree?.CollapseAll();
    async Task RefreshCloud()
    {
        var cloud = rootItems.First(r => r.LazyLoad);
        if (tree != null) await tree.RefreshAsync(cloud);
    }

    void OnSelected(TreeItemEventArgs<FileNode> e) => status = $"Selected: {e.Item.Name}";
    void OnExpanded(TreeItemEventArgs<FileNode> e) => status = $"Expanded: {e.Item.Name}";
    void OnCollapsed(TreeItemEventArgs<FileNode> e) => status = $"Collapsed: {e.Item.Name}";
    void OnLoadFailed(TreeLoadFailedEventArgs<FileNode> e) => status = $"Load failed: {e.Exception.Message}";

    void OnDropped(TreeItemDroppedEventArgs<FileNode> e)
    {
        var srcList = FindParentList(e.SourceItem);
        var tgtList = FindParentList(e.TargetItem);
        if (srcList == null || tgtList == null) return;
        srcList.Remove(e.SourceItem);
        var idx = tgtList.IndexOf(e.TargetItem);
        tgtList.Insert(idx + 1, e.SourceItem);
        status = $"Moved {e.SourceItem.Name} after {e.TargetItem.Name}";
        StateHasChanged();
    }

    List<FileNode>? FindParentList(FileNode item)
    {
        if (rootItems.Contains(item)) return rootItems;
        return FindParentListIn(rootItems, item);
    }

    static List<FileNode>? FindParentListIn(List<FileNode> nodes, FileNode item)
    {
        foreach (var n in nodes)
        {
            if (n.Children == null) continue;
            if (n.Children.Contains(item)) return n.Children;
            var nested = FindParentListIn(n.Children, item);
            if (nested != null) return nested;
        }
        return null;
    }

    public class FileNode
    {
        public string Name { get; set; } = "";
        public string Icon { get; set; } = "";
        public bool IsFolder { get; set; }
        public bool IsLocked { get; set; }
        public bool LazyLoad { get; set; }
        public List<FileNode>? Children { get; set; }
    }
}
