@page "/toast"
@inject IToastService ToastService

<PageTitle>Toast</PageTitle>

<h1>Toast Service</h1>

<p class="status-message">@statusMessage</p>

<!-- ============================================================ -->
<!--  CONFIGURATION -->
<!-- ============================================================ -->
<section class="demo-section">
    <h2>Configuration</h2>

    <div class="toast-form">
        <label>Message</label>
        <input type="text" @bind="toastText" />

        <label>Position</label>
        <select @bind="selectedPosition">
            @foreach (var v in Enum.GetValues<ToastPosition>())
            {
                <option value="@v">@v</option>
            }
        </select>

        <label>Display Mode</label>
        <select @bind="selectedDisplayMode">
            @foreach (var v in Enum.GetValues<ToastDisplayMode>())
            {
                <option value="@v">@v</option>
            }
        </select>

        <label>Queue Mode</label>
        <select @bind="selectedQueueMode">
            @foreach (var v in Enum.GetValues<ToastQueueMode>())
            {
                <option value="@v">@v</option>
            }
        </select>

        <label>Spinner</label>
        <select @bind="selectedSpinner">
            @foreach (var v in Enum.GetValues<ToastSpinnerPosition>())
            {
                <option value="@v">@v</option>
            }
        </select>

        <label>Text Overflow</label>
        <select @bind="selectedTextOverflow">
            @foreach (var v in Enum.GetValues<ToastTextOverflow>())
            {
                <option value="@v">@v</option>
            }
        </select>
    </div>

    <div class="toast-form" style="margin-top:12px;">
        <label>Duration (seconds)</label>
        <div class="stepper-row">
            <input type="range" min="0" max="30" step="1" @bind="durationSeconds" />
            <span>@(durationSeconds)s</span>
        </div>

        <label>Corner Radius</label>
        <div class="stepper-row">
            <input type="range" min="0" max="40" step="2" @bind="cornerRadius" />
            <span>@cornerRadius</span>
        </div>

        <label>Marquee Speed (px/s)</label>
        <div class="stepper-row">
            <input type="range" min="10" max="200" step="10" @bind="marqueeSpeed" />
            <span>@marqueeSpeed</span>
        </div>

        <label>Marquee Loops (0 = use duration)</label>
        <div class="stepper-row">
            <input type="range" min="0" max="5" step="1" @bind="marqueeLoops" />
            <span>@marqueeLoops</span>
        </div>
    </div>

    <div class="toast-form" style="margin-top:12px;">
        <label class="toggle-row">
            <span>Dismiss on Tap</span>
            <input type="checkbox" @bind="dismissOnTap" />
        </label>
        <label class="toggle-row">
            <span>Show Progress Bar</span>
            <input type="checkbox" @bind="showProgressBar" />
        </label>
    </div>

    <button @onclick="ShowConfiguredToast" style="margin-top:16px;">Show Toast</button>
</section>

<!-- ============================================================ -->
<!--  MANUAL DISMISS -->
<!-- ============================================================ -->
<section class="demo-section">
    <h2>Manual Dismiss</h2>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button @onclick="SpinnerToast">Show Persistent Toast</button>
        <button @onclick="DismissManual" style="background:#DC2626;">Dismiss</button>
    </div>
</section>

<!-- ============================================================ -->
<!--  THEMED TYPES -->
<!-- ============================================================ -->
<section class="demo-section">
    <h2>Themed Types</h2>
    <div style="display:flex;gap:8px;flex-wrap:wrap;">
        <button @onclick="InfoToast" style="background:#1E40AF;">Info</button>
        <button @onclick="SuccessToast" style="background:#166534;">Success</button>
        <button @onclick="WarningToast" style="background:#854D0E;">Warning</button>
        <button @onclick="DangerToast" style="background:#9A3412;">Danger</button>
        <button @onclick="CriticalToast" style="background:#991B1B;">Critical</button>
    </div>
</section>

<!-- ============================================================ -->
<!--  CUSTOM STYLING -->
<!-- ============================================================ -->
<section class="demo-section">
    <h2>Custom Styling</h2>
    <button @onclick="StyledToast" style="background:#312E81;">Custom Colors &amp; Border</button>
</section>

@code {
    string toastText = "This is a really long toast message that is meant to demonstrate what happens when the text content exceeds the available width of the toast container";
    string statusMessage = "Configure and tap Show Toast";
    IDisposable? manualToast;

    // Configuration state
    ToastPosition selectedPosition = ToastPosition.Bottom;
    ToastDisplayMode selectedDisplayMode = ToastDisplayMode.Pill;
    ToastQueueMode selectedQueueMode = ToastQueueMode.Queue;
    ToastSpinnerPosition selectedSpinner = ToastSpinnerPosition.None;
    ToastTextOverflow selectedTextOverflow = ToastTextOverflow.Ellipsis;
    int durationSeconds = 3;
    int cornerRadius = 20;
    int marqueeSpeed = 40;
    int marqueeLoops = 1;
    bool dismissOnTap = true;
    bool showProgressBar;

    async Task ShowConfiguredToast()
    {
        await ToastService.ShowAsync(toastText, cfg =>
        {
            cfg.Position = selectedPosition;
            cfg.DisplayMode = selectedDisplayMode;
            cfg.QueueMode = selectedQueueMode;
            cfg.Spinner = selectedSpinner;
            cfg.Duration = TimeSpan.FromSeconds(durationSeconds);
            cfg.CornerRadius = cornerRadius;
            cfg.DismissOnTap = dismissOnTap;
            cfg.ShowProgressBar = showProgressBar;
            cfg.TextOverflow = selectedTextOverflow;
            cfg.MarqueeSpeedPixelsPerSecond = marqueeSpeed;
            cfg.MarqueeLoops = marqueeLoops;
        });
        statusMessage = "Configured toast shown";
    }

    async Task SpinnerToast()
    {
        manualToast?.Dispose();
        manualToast = await ToastService.ShowAsync("Uploading file...", cfg =>
        {
            cfg.Spinner = ToastSpinnerPosition.Left;
            cfg.Duration = TimeSpan.Zero;
            cfg.DismissOnTap = false;
        });
        statusMessage = "Persistent toast shown (tap Dismiss to close)";
    }

    void DismissManual()
    {
        manualToast?.Dispose();
        manualToast = null;
        statusMessage = "Manual toast dismissed";
    }

    async Task StyledToast()
    {
        await ToastService.ShowAsync("Custom styled toast", cfg =>
        {
            cfg.BackgroundColor = "#312E81";
            cfg.TextColor = "#E0E7FF";
            cfg.BorderColor = "#6D28D9";
            cfg.BorderThickness = 1.5;
            cfg.CornerRadius = 12;
        });
        statusMessage = "Styled toast shown";
    }

    async Task InfoToast()
    {
        await ToastService.InfoAsync(toastText);
        statusMessage = "Info toast shown";
    }

    async Task SuccessToast()
    {
        await ToastService.SuccessAsync(toastText);
        statusMessage = "Success toast shown";
    }

    async Task WarningToast()
    {
        await ToastService.WarningAsync(toastText);
        statusMessage = "Warning toast shown";
    }

    async Task DangerToast()
    {
        await ToastService.DangerAsync(toastText);
        statusMessage = "Danger toast shown";
    }

    async Task CriticalToast()
    {
        await ToastService.CriticalAsync(toastText);
        statusMessage = "Critical toast shown";
    }
}
