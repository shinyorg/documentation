@page "/staggeredgrid"

<PageTitle>Staggered Grid</PageTitle>

<h1>Staggered Grid</h1>

<section class="demo-section">
    <h2>Pinterest-style Masonry</h2>
    <div style="margin-bottom:12px;">
        <label>Columns: </label>
        <button @onclick="@(() => columns = Math.Max(1, columns - 1))">-</button>
        <strong>@columns</strong>
        <button @onclick="@(() => columns = Math.Min(5, columns + 1))">+</button>
    </div>

    <StaggeredGrid TItem="PinItem" Items="@pins" ColumnCount="@columns"
                   ColumnSpacing="12" RowSpacing="12"
                   ItemSelected="@(item => selectedItem = item.Title)">
        <ItemTemplate Context="item">
            <div style="height:@(item.Height)px;border-radius:12px;background:@item.Color;padding:16px;color:white;display:flex;flex-direction:column;justify-content:space-between;">
                <span style="font-size:24px;">@item.Icon</span>
                <div>
                    <div style="font-weight:600;">@item.Title</div>
                    <div style="font-size:12px;opacity:0.8;">@item.Category</div>
                </div>
            </div>
        </ItemTemplate>
        <EmptyTemplate>
            <p>No items to display.</p>
        </EmptyTemplate>
    </StaggeredGrid>

    @if (selectedItem is not null)
    {
        <p style="margin-top:12px;">Selected: <strong>@selectedItem</strong></p>
    }
</section>

<section class="demo-section">
    <h2>Image Gallery</h2>
    <StaggeredGrid TItem="PinItem" Items="@galleryItems" ColumnCount="3"
                   ColumnSpacing="8" RowSpacing="8">
        <ItemTemplate Context="item">
            <div style="height:@(item.Height)px;border-radius:8px;background:linear-gradient(180deg, @item.Color 0%, @item.GradientEnd 100%);display:flex;align-items:center;justify-content:center;color:white;font-size:32px;box-shadow:0 2px 8px rgba(0,0,0,0.1);">
                @item.Icon
            </div>
        </ItemTemplate>
    </StaggeredGrid>
</section>

@code {
    int columns = 3;
    string? selectedItem;

    List<PinItem> pins = new()
    {
        new("Travel", "Adventure", 180, "#E53E3E", "✈️"),
        new("Food", "Recipes", 240, "#DD6B20", "🍕"),
        new("Nature", "Photography", 160, "#38A169", "🌿"),
        new("Tech", "Gadgets", 200, "#3182CE", "💻"),
        new("Art", "Design", 280, "#805AD5", "🎨"),
        new("Music", "Playlists", 150, "#D53F8C", "🎵"),
        new("Fitness", "Workouts", 220, "#319795", "💪"),
        new("Books", "Reading", 190, "#B7791F", "📚"),
        new("Fashion", "Style", 260, "#C53030", "👗"),
        new("Gaming", "Reviews", 170, "#2B6CB0", "🎮"),
        new("DIY", "Crafts", 210, "#2F855A", "🔨"),
        new("Pets", "Animals", 250, "#6B46C1", "🐾"),
    };

    List<PinItem> galleryItems = new()
    {
        new("Sunset", "", 200, "#F56565", "🌅") { GradientEnd = "#FC8181" },
        new("Lake", "", 160, "#4299E1", "🏞️") { GradientEnd = "#90CDF4" },
        new("Flowers", "", 240, "#48BB78", "🌸") { GradientEnd = "#9AE6B4" },
        new("Stars", "", 180, "#667EEA", "⭐") { GradientEnd = "#A3BFFA" },
        new("Snow", "", 220, "#A0AEC0", "❄️") { GradientEnd = "#E2E8F0" },
        new("Autumn", "", 190, "#ED8936", "🍂") { GradientEnd = "#FBD38D" },
        new("Rain", "", 250, "#4FD1C5", "🌧️") { GradientEnd = "#B2F5EA" },
        new("Fire", "", 170, "#F6AD55", "🔥") { GradientEnd = "#FEFCBF" },
        new("Moon", "", 210, "#9F7AEA", "🌙") { GradientEnd = "#D6BCFA" },
    };

    record PinItem(string Title, string Category, int Height, string Color, string Icon)
    {
        public string GradientEnd { get; init; } = Color;
    }
}
