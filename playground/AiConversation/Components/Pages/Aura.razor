@page "/aura"
@inject IAiConversationService AiService
@implements IDisposable

<PageTitle>Aura</PageTitle>

<div class="aura-container">
    <div class="aura-orb-area">
        <div class="aura-ripple @stateClass"></div>
        <div class="aura-outer-ring @stateClass"></div>
        <div class="aura-inner-orb @stateClass"></div>
    </div>

    <div class="aura-status" style="color: @auraColor">@AiService.Status</div>

    @if (isResponseVisible)
    {
        <div class="aura-response-panel">
            <div class="aura-response-header">
                <span>Copilot</span>
                <button class="aura-dismiss" @onclick="DismissResponse">&times;</button>
            </div>
            <p>@lastResponseText</p>
        </div>
    }
</div>

@code {
    string? lastResponseText;
    bool isResponseVisible;
    string auraColor = "#6C5CE7";
    string stateClass = "idle";

    protected override void OnInitialized()
    {
        AiService.StatusChanged += OnStatusChanged;
        AiService.AiResponded += OnAiResponded;
        UpdateState();
    }

    void OnStatusChanged(AiState state)
    {
        InvokeAsync(() =>
        {
            UpdateState();
            StateHasChanged();
        });
    }

    void OnAiResponded(AiResponse response)
    {
        if (response.WasReadAloud)
            return;

        if (response.Response.Text is { } text)
        {
            InvokeAsync(() =>
            {
                lastResponseText = text;
                isResponseVisible = true;
                StateHasChanged();
            });
        }
    }

    void UpdateState()
    {
        (auraColor, stateClass) = AiService.Status switch
        {
            AiState.Listening => ("#00D2FF", "listening"),
            AiState.Thinking => ("#A29BFE", "thinking"),
            AiState.Responding => ("#00B894", "responding"),
            _ => ("#6C5CE7", "idle")
        };
    }

    void DismissResponse() => isResponseVisible = false;

    public void Dispose()
    {
        AiService.StatusChanged -= OnStatusChanged;
        AiService.AiResponded -= OnAiResponded;
    }
}
