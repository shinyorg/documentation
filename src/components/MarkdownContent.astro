---
import Default from '@astrojs/starlight/components/MarkdownContent.astro';
import Giscus from './Giscus.astro';

const entry = Astro.locals.starlightRoute?.entry;
const isBlogPost = entry?.id?.startsWith('blog/') ?? false;
const optedIn = entry?.data?.comments === true;
const showGiscus = isBlogPost || optedIn;
---

<Default><slot /></Default>
{showGiscus && <Giscus />}
