---
export interface Props {
    name: string;
    showLabel?: boolean;
    showPreviewVersion?: boolean;
}

const { name, showPreviewVersion, showLabel } = Astro.props as Props;

const v = showPreviewVersion === true ? 'vpre' : 'v';
let imgUrl: string = `https://img.shields.io/nuget/${v}/${name}?style=for-the-badge&logo=nuget`;
if (showLabel === true) {
    imgUrl += `&label=${name}`;
}
const nugetUrl: string = `https://www.nuget.org/packages/${name}`;
---
<a href={nugetUrl} target="_blank" rel="noopener noreferrer"><img src={imgUrl} alt={`NuGet package ${name}`} /></a>