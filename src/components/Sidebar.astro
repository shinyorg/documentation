---
import Default from '@astrojs/starlight/components/Sidebar.astro';
import TopicsDropdown from 'starlight-sidebar-topics-dropdown/TopicsDropdown.astro';

// Blog (and any other pages excluded from sidebar-topics) have no current
// topic, which makes TopicsDropdown crash at `currentTopic.icon`. Only render
// the dropdown when a current topic is available.
const topics = Astro.locals.starlightSidebarTopics?.topics ?? [];
const hasCurrentTopic = topics.some((topic) => topic.isCurrent);
---

{/* Render the topics dropdown menu — only when a current topic exists. */}
{hasCurrentTopic && <TopicsDropdown />}
{/* Render the default sidebar. */}
<Default><slot /></Default>