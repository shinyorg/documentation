---
import { sidebarTopics } from '../sidebar-topics.mjs';

/**
 * Recursively collects items with `jumpTo: true` from the sidebar config.
 * Returns an array of { topicLabel, label, link } objects.
 */
function collectJumpToItems(topics) {
  const results = [];

  for (const topic of topics) {
    const topicLabel = topic.label;
    walkItems(topic.items || [], topicLabel, results);
  }

  return results;
}

function resolveLink(item) {
  if (item.link) {
    // Ensure link starts with /
    return item.link.startsWith('/') ? item.link : `/${item.link}`;
  }
  // Use first child's link
  if (item.items && item.items.length > 0) {
    return resolveLink(item.items[0]);
  }
  return '#';
}

function walkItems(items, topicLabel, results) {
  for (const item of items) {
    if (item.jumpTo) {
      results.push({
        topicLabel,
        label: item.label,
        link: resolveLink(item),
      });
    }
    // Also check children (for cases like "Input Controls" where jumpTo is on the children)
    if (item.items) {
      walkItems(item.items, topicLabel, results);
    }
  }
}

const jumpToItems = collectJumpToItems(sidebarTopics);

// Group by topic label, preserving order
const grouped = [];
const seen = new Set();
for (const item of jumpToItems) {
  if (!seen.has(item.topicLabel)) {
    seen.add(item.topicLabel);
    grouped.push({ label: item.topicLabel, items: [] });
  }
  grouped.find(g => g.label === item.topicLabel).items.push(item);
}
---

<div class="quick-nav">
  <div class="quick-nav-inner">
    <select id="library-select" class="quick-nav-select">
      <option value="">Jump to a library...</option>
      {grouped.map(group => (
        <optgroup label={group.label}>
          {group.items.map(item => (
            <option value={item.link}>{item.label}</option>
          ))}
        </optgroup>
      ))}
    </select>
    <button id="library-go" class="quick-nav-btn quick-nav-go">GO</button>
    <a href="/foundation/appbuilder/" class="quick-nav-btn quick-nav-appbuilder">App Builder</a>
  </div>
</div>

<script>
(function() {
  var goBtn = document.getElementById('library-go');
  var sel = document.getElementById('library-select');
  if (!goBtn || !sel) return;
  goBtn.addEventListener('click', function() {
    if (sel.value) window.location.href = sel.value;
  });
  sel.addEventListener('keydown', function(e) {
    if (e.key === 'Enter' && sel.value) window.location.href = sel.value;
  });
})();
</script>
