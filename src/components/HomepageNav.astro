---
import { sidebarTopics } from '../sidebar-topics.mjs';

function resolveLink(item) {
  if (item.link) {
    return /^https?:\/\//.test(item.link) || item.link.startsWith('/')
      ? item.link
      : `/${item.link}`;
  }
  if (item.items?.length) return resolveLink(item.items[0]);
  return '#';
}

function collectTopItems(items) {
  const results = [];
  for (const item of items) {
    if (item.expandInHomenav && item.items?.length) {
      for (const child of item.items) {
        if (!child.label) continue;
        results.push({
          label: child.label,
          link: resolveLink(child),
          attrs: child.attrs,
        });
      }
      continue;
    }
    if (item.label) {
      results.push({
        label: item.label,
        link: resolveLink(item),
      });
    }
  }
  return results;
}

// Fully flatten a topic into every individual control (used for the long
// Controls panel). Any node marked `jumpTo` is a standalone control — emit it,
// but keep recursing so controls nested inside a control's own group (e.g. the
// Floating Panels "Derived Controls") still surface. Sub-pages of a control
// have no `jumpTo`, so they're skipped.
function collectControls(items, out = []) {
  for (const item of items) {
    if (item.jumpTo === true && item.label) {
      out.push({ label: item.label, link: resolveLink(item), attrs: item.attrs });
    }
    if (item.items?.length) collectControls(item.items, out);
  }
  return out;
}

let topics = sidebarTopics.map(topic => ({
  label: topic.label,
  icon: topic.icon,
  link: resolveLink(topic),
  flatten: topic.flattenInHomenav === true,
  items: topic.flattenInHomenav
    ? collectControls(topic.items || []).sort((a, b) => a.label.localeCompare(b.label))
    : collectTopItems(topic.items || []),
}));

// Push flattened (long) panels to the bottom — they'd otherwise bury the
// shorter topic panels above them.
topics = [...topics.filter(t => !t.flatten), ...topics.filter(t => t.flatten)];
---

<button class="homenav-toggle" id="homenav-toggle" aria-label="Browse all sections">
  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
  <span>Menu</span>
</button>

<div class="homenav-backdrop" id="homenav-backdrop"></div>

<nav class="homenav-panel" id="homenav-panel" aria-label="Site navigation">
  <div class="homenav-body">
    {topics.map((topic, i) => (
      <section class="homenav-topic" data-topic={i % 9}>
        <div class="homenav-topic-header">
          <span class="homenav-topic-label">{topic.label}</span>
        </div>
        <ul class="homenav-items">
          {topic.items.map(item => (
            <li><a href={item.link} {...(item.attrs || {})}>{item.label}</a></li>
          ))}
        </ul>
      </section>
    ))}
  </div>

  <div class="homenav-footer">
    <a href="/foundation/appbuilder/" class="homenav-appbuilder">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
      App Builder
    </a>
  </div>
</nav>

<style>
  /* ── Toggle Button ─────────────────────────────────────── */
  .homenav-toggle {
    position: fixed;
    left: 1rem;
    top: calc(var(--sl-nav-height, 3.5rem) + 1rem);
    z-index: 100;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1.1rem 0.5rem 0.95rem;
    border-radius: 999px;
    border: 1px solid transparent;
    background: linear-gradient(135deg, var(--shiny-purple-vivid, #6A3DF0), var(--shiny-green-vivid, #0FBF7A));
    color: #fff;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.01em;
    cursor: pointer;
    font-family: inherit;
    box-shadow:
      0 2px 6px rgba(0, 0, 0, 0.12),
      0 6px 18px rgba(106, 61, 240, 0.35);
    transition: all 0.2s ease;
  }

  .homenav-toggle svg {
    color: #fff;
  }

  .homenav-toggle:hover {
    box-shadow:
      0 3px 10px rgba(0, 0, 0, 0.16),
      0 10px 30px rgba(106, 61, 240, 0.55);
    transform: translateY(-1px);
  }

  .homenav-toggle:active {
    transform: translateY(0);
  }

  /* On mobile, anchor to bottom-right so it can't overlap the
     starlight-announcement banner at the top of the page. */
  @media (max-width: 50rem) {
    .homenav-toggle {
      top: auto;
      left: auto;
      right: 1rem;
      bottom: calc(1rem + env(safe-area-inset-bottom, 0px));
      padding: 0.65rem 1.2rem 0.65rem 1.1rem;
      box-shadow:
        0 2px 6px rgba(0, 0, 0, 0.18),
        0 8px 26px rgba(106, 61, 240, 0.5);
    }
  }

  /* ── Backdrop ──────────────────────────────────────────── */
  .homenav-backdrop {
    position: fixed;
    margin: 0;
    inset: 0;
    z-index: 200;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(2px);
    -webkit-backdrop-filter: blur(2px);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .homenav-backdrop.open {
    opacity: 1;
    visibility: visible;
  }

  /* ── Panel ─────────────────────────────────────────────── */
  .homenav-panel {
    position: fixed;
    /* Zero the prose top-margin Starlight applies to children of
       .sl-markdown-content — it offsets even a fixed element and opens a
       gap below the toolbar. */
    margin: 0;
    top: var(--sl-nav-height, 3.5rem);
    left: 0;
    bottom: 0;
    z-index: 201;
    width: min(24rem, 88vw);
    background: var(--sl-color-bg);
    border-right: 1px solid var(--sl-color-gray-6);
    box-shadow: 8px 0 30px rgba(0, 0, 0, 0.15);
    transform: translateX(-100%);
    transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  :global(:root[data-theme='dark']) .homenav-panel {
    border-right-color: var(--sl-color-gray-5);
    box-shadow: 8px 0 30px rgba(0, 0, 0, 0.35);
  }

  .homenav-panel.open {
    transform: translateX(0);
  }

  /* ── Body ──────────────────────────────────────────────── */
  .homenav-body {
    flex: 1;
    overflow-y: auto;
    /* No vertical padding: the topic banners run edge-to-edge against the
       toolbar above and the footer below. */
    padding: 0;
  }

  .homenav-body::-webkit-scrollbar {
    width: 5px;
  }

  .homenav-body::-webkit-scrollbar-track {
    background: transparent;
  }

  .homenav-body::-webkit-scrollbar-thumb {
    background: var(--sl-color-gray-5);
    border-radius: 5px;
  }

  .homenav-body::-webkit-scrollbar-thumb:hover {
    background: var(--shiny-purple-vivid, #6A3DF0);
  }

  /* ── Topic (collapsible) ───────────────────────────────── */
  .homenav-topic {
    margin: 0;
    border-bottom: 1px solid var(--sl-color-gray-6);
  }

  :global(:root[data-theme='dark']) .homenav-topic {
    border-bottom-color: var(--sl-color-gray-5);
  }

  .homenav-topic:last-child {
    border-bottom: none;
  }

  .homenav-topic-header {
    padding: 0.6rem 1.25rem;
    font-size: 0.82rem;
    font-weight: 800;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    text-align: left;
    background: var(--topic-color);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.28);
  }

  /* ── Per-section accent colour ─────────────────────────── */
  .homenav-topic[data-topic='0'] { --topic-color: #6A3DF0; }
  .homenav-topic[data-topic='1'] { --topic-color: #0FBF7A; }
  .homenav-topic[data-topic='2'] { --topic-color: #0091EA; }
  .homenav-topic[data-topic='3'] { --topic-color: #F57C00; }
  .homenav-topic[data-topic='4'] { --topic-color: #E91E63; }
  .homenav-topic[data-topic='5'] { --topic-color: #7CB342; }
  .homenav-topic[data-topic='6'] { --topic-color: #00ACC1; }
  .homenav-topic[data-topic='7'] { --topic-color: #9C27B0; }
  .homenav-topic[data-topic='8'] { --topic-color: #F4511E; }

  /* ── Items ─────────────────────────────────────────────── */
  /* Items area = a light wash of the banner colour. */
  .homenav-items {
    list-style: none;
    margin: 0;
    padding: 0.4rem 0 0.6rem;
    background: color-mix(in srgb, var(--topic-color) 9%, var(--sl-color-bg));
  }

  :global(:root[data-theme='dark']) .homenav-items {
    background: color-mix(in srgb, var(--topic-color) 16%, var(--sl-color-bg));
  }

  .homenav-items li {
    margin: 0;
    padding: 0;
  }

  /* Vibrant, on-hue link text tuned for contrast in each mode. */
  .homenav-items a {
    display: block;
    padding: 0.4rem 1.25rem 0.4rem 1.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: color-mix(in srgb, var(--topic-color), black 24%);
    text-decoration: none;
    text-align: left;
    transition: all 0.12s ease;
  }

  :global(:root[data-theme='dark']) .homenav-items a {
    color: color-mix(in srgb, var(--topic-color), white 48%);
  }

  .homenav-items a:hover {
    color: #fff;
    background: var(--topic-color);
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.28);
  }

  :global(:root[data-theme='dark']) .homenav-items a:hover {
    color: #fff;
  }

  /* ── Footer ────────────────────────────────────────────── */
  .homenav-footer {
    /* Zero the prose top-margin Starlight applies to any sibling-preceded
       descendant of .sl-markdown-content — without this the footer floats
       1rem below the scroll body, leaving a gap above the App Builder button. */
    margin: 0;
    flex-shrink: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    border-top: 1px solid var(--sl-color-gray-6);
    background: linear-gradient(135deg, rgba(106, 61, 240, 0.12), rgba(166, 217, 0, 0.08));
  }

  :global(:root[data-theme='dark']) .homenav-footer {
    border-top-color: var(--sl-color-gray-5);
    background: linear-gradient(135deg, rgba(155, 123, 255, 0.16), rgba(207, 250, 18, 0.07));
  }

  .homenav-appbuilder {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.6rem 1rem;
    border-radius: 0.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    text-decoration: none;
    color: white;
    background: linear-gradient(135deg, var(--shiny-purple-vivid, #6A3DF0), var(--shiny-green-vivid, #0FBF7A));
    box-shadow: 0 2px 10px rgba(106, 61, 240, 0.4);
    transition: all 0.2s ease;
  }

  .homenav-appbuilder:hover {
    box-shadow: 0 6px 20px rgba(106, 61, 240, 0.55);
    transform: translateY(-1px);
    color: white;
  }

  .homenav-appbuilder:active {
    transform: translateY(0);
  }
</style>

<script>
(function() {
  var toggle = document.getElementById('homenav-toggle');
  var panel = document.getElementById('homenav-panel');
  var backdrop = document.getElementById('homenav-backdrop');

  if (!toggle || !panel || !backdrop) return;

  function open() {
    // Sit flush under the real toolbar bottom — which moves down when the
    // announcement banner is present, so --sl-nav-height alone isn't enough.
    var header = document.querySelector('header.header');
    if (header) {
      panel.style.top = Math.max(0, header.getBoundingClientRect().bottom) + 'px';
    }
    panel.classList.add('open');
    backdrop.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function shut() {
    panel.classList.remove('open');
    backdrop.classList.remove('open');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', open);
  backdrop.addEventListener('click', shut);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && panel.classList.contains('open')) shut();
  });
})();
</script>
