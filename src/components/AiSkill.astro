---
export interface Props {
    pluginName?: string;
    skillName?: string;
    repoUrl?: string;
}

const skillToPlugin: Record<string, string> = {
    'shiny-core': 'shiny-client',
    'shiny-bluetoothle': 'shiny-client',
    'shiny-ble-hosting': 'shiny-client',
    'shiny-jobs': 'shiny-client',
    'shiny-locations': 'shiny-client',
    'shiny-http-transfers': 'shiny-client',
    'shiny-notifications': 'shiny-client',
    'shiny-push': 'shiny-client',
    'shiny-music': 'shiny-client',
    'shiny-obd': 'shiny-client',
    'shiny-firebase': 'shiny-client',
    'shiny-permissions': 'shiny-client',
    'shiny-maui-shell': 'shiny-maui',
    'shiny-maui-scheduler': 'shiny-maui',
    'shiny-tableview': 'shiny-maui',
    'shiny-contactstore': 'shiny-maui',
    'shiny-maui-mermaid-diagrams': 'shiny-maui',
    'shiny-mediator': 'shiny-mediator',
    'shiny-documentdb': 'shiny-data',
    'shiny-spatial': 'shiny-data',
    'shiny-aspire': 'shiny-aspire',
    'shiny-di': 'shiny-extensions',
    'shiny-stores': 'shiny-extensions',
    'shiny-reflector': 'shiny-extensions',
    'localizegen': 'shiny-extensions',
    'shiny-maui-hosting': 'shiny-extensions',
    'shiny-web-hosting': 'shiny-extensions',
};

const plugins = [
    { name: 'shiny-client', label: 'Client', description: 'BLE, GPS, Jobs, Notifications, Push, HTTP Transfers, OBD, Music — iOS, Android, Windows, MacOS, Linux, Web' },
    { name: 'shiny-maui', label: 'MAUI', description: 'Shell, Scheduler, TableView, Contact Store, Mermaid Diagrams' },
    { name: 'shiny-mediator', label: 'Mediator', description: 'Mediator/CQRS with middleware and source generators' },
    { name: 'shiny-data', label: 'Data', description: 'DocumentDB and Spatial data libraries' },
    { name: 'shiny-aspire', label: 'Aspire', description: 'Orleans and Gluetun Aspire integrations' },
    { name: 'shiny-extensions', label: 'Extensions', description: 'DI, Stores, Reflector, Localization, Hosting modules' },
];

const { skillName, pluginName: pluginNameProp, repoUrl = 'https://github.com/shinyorg/skills' } = Astro.props as Props;
const pluginName = pluginNameProp || (skillName ? skillToPlugin[skillName] : undefined);
const isHomepage = !pluginName;

const claudeMarketplaceAdd = 'claude plugin marketplace add shinyorg/skills';
const claudeInstallPlugin = pluginName ? `claude plugin install ${pluginName}@shiny` : undefined;
// TODO: Update with correct Copilot CLI install commands once available

const skillUrl = skillName
    ? `${repoUrl}/blob/main/skills/${skillName}/SKILL.md`
    : repoUrl;
const pluginUrl = pluginName
    ? `${repoUrl}/tree/main/plugins/${pluginName}`
    : repoUrl;
---
<div class="ai-skill not-content">
    <div class="ai-skill__tabs" role="tablist">
        <button class="ai-skill__tab ai-skill__tab--active" role="tab" aria-selected="true" data-tab="claude">Claude Code</button>
        <button class="ai-skill__tab" role="tab" aria-selected="false" data-tab="copilot">GitHub Copilot</button>
    </div>

    {/* Claude Code Panel */}
    <div class="ai-skill__panel ai-skill__panel--active" data-panel="claude">
        {isHomepage ? (
            <Fragment>
                <p class="ai-skill__section-label">Step 1 — Add the marketplace:</p>
                <div class="ai-skill__code-block">
                    <code>{claudeMarketplaceAdd}</code>
                    <button class="ai-skill__copy" aria-label="Copy marketplace command" data-copy={claudeMarketplaceAdd}>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                        </svg>
                    </button>
                </div>
                <p class="ai-skill__section-label">Step 2 — Install plugins:</p>
                <div class="ai-skill__plugin-list">
                    {plugins.map(p => {
                        const cmd = `claude plugin install ${p.name}@shiny`;
                        return (
                            <div class="ai-skill__plugin-row">
                                <div class="ai-skill__code-block">
                                    <code>{cmd}</code>
                                    <button class="ai-skill__copy" aria-label={`Copy ${p.name} command`} data-copy={cmd}>
                                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                                        </svg>
                                    </button>
                                </div>
                                <span class="ai-skill__plugin-desc">{p.description}</span>
                            </div>
                        );
                    })}
                </div>
            </Fragment>
        ) : (
            <Fragment>
                <p class="ai-skill__section-label">Step 1 — Add the marketplace:</p>
                <div class="ai-skill__code-block">
                    <code>{claudeMarketplaceAdd}</code>
                    <button class="ai-skill__copy" aria-label="Copy marketplace command" data-copy={claudeMarketplaceAdd}>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                        </svg>
                    </button>
                </div>
                <p class="ai-skill__section-label">Step 2 — Install the plugin:</p>
                <div class="ai-skill__code-block">
                    <code>{claudeInstallPlugin}</code>
                    <button class="ai-skill__copy" aria-label="Copy install command" data-copy={claudeInstallPlugin}>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                        </svg>
                    </button>
                </div>
            </Fragment>
        )}
    </div>

    {/* GitHub Copilot Panel */}
    <div class="ai-skill__panel" data-panel="copilot">
        <p class="ai-skill__hint">Coming soon — Copilot plugin install instructions will be added here.</p>
    </div>

    <a class="ai-skill__view-link" href={pluginName ? pluginUrl : repoUrl} target="_blank" rel="noopener noreferrer">
        {pluginName ? `View ${pluginName} Plugin` : 'View Skills Repository'}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
    </a>
</div>

<script>
    document.querySelectorAll('.ai-skill').forEach((container) => {
        const tabs = container.querySelectorAll('.ai-skill__tab');
        const panels = container.querySelectorAll('.ai-skill__panel');

        tabs.forEach((tab) => {
            tab.addEventListener('click', () => {
                const target = (tab as HTMLElement).dataset.tab;
                tabs.forEach((t) => {
                    t.classList.remove('ai-skill__tab--active');
                    t.setAttribute('aria-selected', 'false');
                });
                panels.forEach((p) => p.classList.remove('ai-skill__panel--active'));
                tab.classList.add('ai-skill__tab--active');
                tab.setAttribute('aria-selected', 'true');
                container.querySelector(`[data-panel="${target}"]`)?.classList.add('ai-skill__panel--active');
            });
        });

        container.querySelectorAll('.ai-skill__copy').forEach((btn) => {
            btn.addEventListener('click', () => {
                const text = (btn as HTMLElement).dataset.copy || '';
                navigator.clipboard.writeText(text).then(() => {
                    btn.classList.add('ai-skill__copy--copied');
                    setTimeout(() => btn.classList.remove('ai-skill__copy--copied'), 2000);
                });
            });
        });
    });
</script>
