---
export interface Props {
    skillName?: string;
    repoUrl?: string;
}

const { skillName, repoUrl = 'https://github.com/shinyorg/skills' } = Astro.props as Props;
const skillUrl = skillName
    ? `${repoUrl}/blob/main/skills/${skillName}/SKILL.md`
    : repoUrl;
const claudeCommand = skillName
    ? `claude plugin add github:shinyorg/skills/${skillName}`
    : 'claude plugin add github:shinyorg/skills';
---
<div class="ai-skill not-content">
    <div class="ai-skill__tabs" role="tablist">
        <button class="ai-skill__tab ai-skill__tab--active" role="tab" aria-selected="true" data-tab="claude">Claude Code</button>
        <button class="ai-skill__tab" role="tab" aria-selected="false" data-tab="copilot">GitHub Copilot</button>
    </div>
    <div class="ai-skill__panel ai-skill__panel--active" data-panel="claude">
        <div class="ai-skill__code-block">
            <code>{claudeCommand}</code>
            <button class="ai-skill__copy" aria-label="Copy to clipboard" data-copy={claudeCommand}>
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
                    <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
                </svg>
            </button>
        </div>
    </div>
    <div class="ai-skill__panel" data-panel="copilot">
        {skillName ? (
            <ol class="ai-skill__steps">
                <li>Open the <a href={skillUrl} target="_blank" rel="noopener noreferrer"><strong>{skillName}</strong></a> skill file and copy its contents</li>
                <li>In your repository, create <code>.github/copilot-instructions.md</code> if it doesn't exist</li>
                <li>Paste the skill content into that file and save</li>
            </ol>
        ) : (
            <ol class="ai-skill__steps">
                <li>Browse the <a href={repoUrl} target="_blank" rel="noopener noreferrer"><strong>skills repository</strong></a> and open the skill file you need</li>
                <li>In your repository, create <code>.github/copilot-instructions.md</code> if it doesn't exist</li>
                <li>Paste the skill content into that file and save</li>
            </ol>
        )}
        <p class="ai-skill__hint">Copilot will automatically pick up the instructions on your next chat or code completion. You can also use <a href="https://docs.github.com/en/copilot/how-tos/configure-custom-instructions/add-repository-instructions" target="_blank" rel="noopener noreferrer">path-specific instructions</a> by placing the file in <code>.github/instructions/</code> with an <code>applyTo</code> frontmatter pattern.</p>
    </div>
    <a class="ai-skill__view-link" href={skillUrl} target="_blank" rel="noopener noreferrer">
        {skillName ? 'View Skill' : 'View Skills'}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path>
            <polyline points="15 3 21 3 21 9"></polyline>
            <line x1="10" y1="14" x2="21" y2="3"></line>
        </svg>
    </a>
</div>

<script>
    document.querySelectorAll('.ai-skill').forEach((container) => {
        const tabs = container.querySelectorAll('.ai-skill__tab');
        const panels = container.querySelectorAll('.ai-skill__panel');

        tabs.forEach((tab) => {
            tab.addEventListener('click', () => {
                const target = (tab as HTMLElement).dataset.tab;
                tabs.forEach((t) => {
                    t.classList.remove('ai-skill__tab--active');
                    t.setAttribute('aria-selected', 'false');
                });
                panels.forEach((p) => p.classList.remove('ai-skill__panel--active'));
                tab.classList.add('ai-skill__tab--active');
                tab.setAttribute('aria-selected', 'true');
                container.querySelector(`[data-panel="${target}"]`)?.classList.add('ai-skill__panel--active');
            });
        });

        container.querySelectorAll('.ai-skill__copy').forEach((btn) => {
            btn.addEventListener('click', () => {
                const text = (btn as HTMLElement).dataset.copy || '';
                navigator.clipboard.writeText(text).then(() => {
                    btn.classList.add('ai-skill__copy--copied');
                    setTimeout(() => btn.classList.remove('ai-skill__copy--copied'), 2000);
                });
            });
        });
    });
</script>
